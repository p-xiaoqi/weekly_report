# 飞书应用凭证（必须设置，禁止提交到 Git）
FEISHU_APP_ID=your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here
FEISHU_REDIRECT_URI=http://localhost:8080/api/v1/auth/lark/callback
# OAuth 申请的权限范围（空格分隔），留空使用内置默认值。
# 默认: contact:user.base:readonly task:task:readonly calendar:calendar:readonly drive:drive docx:document
# 这些权限还需在开放平台「权限管理」开通并发布版本，用户重新登录授权后才生效，否则任务/日历/文档拉不到。
FEISHU_SCOPES=

# JWT 签名密钥（生产环境必须设置强随机字符串）
JWT_SECRET=

# 提醒机器人配置（可选）
# 方式一：自定义群机器人 webhook（开启"加签"时需配 REMINDER_BOT_SECRET）
FEISHU_BOT_WEBHOOK=
REMINDER_BOT_WEBHOOK=
REMINDER_BOT_SECRET=
# 方式二（推荐）：应用身份发消息，用 FEISHU_APP_ID/FEISHU_APP_SECRET 经 im API 发送，无需 webhook 加签。
# 开启后"测试提醒"会私信当前登录管理员本人；定时提醒发到 REMINDER_CHAT_ID（留空则逐一私信未提交用户）。
# REMINDER_CHAT_ID 支持逗号分隔的多个群（oc_xxx,oc_yyy）。可在系统页面"获取我的群聊"查看 chat_id。
REMINDER_USE_APP=
REMINDER_CHAT_ID=

# 管理员白名单（用于 /api/v1/admin/* 接口，如"测试提醒"）。
# 注意：这是本系统自己的管理员授权，与"飞书群管理员"无关。
# 逗号分隔，可填写邮箱或飞书 open_id；留空则无人能通过管理员鉴权。
ADMIN_EMAILS=
ADMIN_OPEN_IDS=
