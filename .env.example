# 飞书应用凭证（必须设置，禁止提交到 Git）
FEISHU_APP_ID=your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here
FEISHU_REDIRECT_URI=http://localhost:8080/api/v1/auth/lark/callback

# JWT 签名密钥（生产环境必须设置强随机字符串）
JWT_SECRET=

# 提醒机器人配置（可选）
FEISHU_BOT_WEBHOOK=
REMINDER_BOT_WEBHOOK=
REMINDER_BOT_SECRET=

# 管理员白名单（用于 /api/v1/admin/* 接口，如"测试提醒"）。
# 注意：这是本系统自己的管理员授权，与"飞书群管理员"无关。
# 逗号分隔，可填写邮箱或飞书 open_id；留空则无人能通过管理员鉴权。
ADMIN_EMAILS=
ADMIN_OPEN_IDS=
